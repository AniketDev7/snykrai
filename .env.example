# ── Required ──────────────────────────────────────────────────────────────────
SNYK_TOKEN=snyk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SNYK_ORG_ID=00000000-0000-0000-0000-000000000000

# GitHub Personal Access Token (repo + workflow scopes)
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GIT_USER=your-github-username
GIT_ORG=your-github-org

# ── LLM (at least one required) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional overrides ────────────────────────────────────────────────────────
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-2.5-flash

# ── Slack (optional — required for /snykr slash command integration) ──────────
# SLACK_BOT_TOKEN=xoxb-xxxx-xxxx-xxxx
# SLACK_CHANNEL_ID=ABCDFGG
# SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Git author (optional — overrides config.yaml defaults) ───────────────────
# GIT_AUTHOR_EMAIL=snykrai-bot@users.noreply.github.com
